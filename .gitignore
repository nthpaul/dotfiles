.env
.envrc
.DS_Store

# Neovim logs
.nvimlog

# Spotatui token cache (contains access/refresh tokens)
spotatui/.config/spotatui/.spotify_token_cache*.json

# Spotatui local credentials
spotatui/.config/spotatui/client.yml
spotatui/.config/spotatui/streaming_cache/

# Cursor CLI local cache (contains authInfo)
cursor/.cursor/cli-config.json

# Hammerspoon runtime layout profiles (local window positions/titles)
hammerspoon/.hammerspoon/window-layouts/

# gh CLI local auth (username only; no secrets in tracked config.yml)
gh/.config/gh/hosts.yml
